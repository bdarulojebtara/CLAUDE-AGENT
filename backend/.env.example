# ─── MODO DE OPERAÇÃO ────────────────────────────────────────────────────────
DEMO_MODE=true
SETUP_COMPLETED=false

# ─── BANCO DE DADOS MySQL 8+ ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vidrato
DB_USER=root
DB_PASS=

# ─── CACHE Redis (opcional — sistema usa memória se ausente) ──────────────────
REDIS_URL=redis://localhost:6379

# ─── AUTENTICAÇÃO ─────────────────────────────────────────────────────────────
JWT_SECRET=TROCAR_ANTES_DE_PRODUCAO_MINIMO_32_CHARS
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── INTELIGÊNCIA ARTIFICIAL ──────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── SEGURANÇA ────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX=100

# ─── UPLOAD ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
